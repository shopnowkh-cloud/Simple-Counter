modules = ["python-3.12", "nix"]

[deployment]
router = "application"
deploymentTarget = "vm"
run = ["python3", "bot.py"]
build = ["bash", "-c", '''nix-env -iA nixpkgs.nodePackages.pnpm 2>&1 && echo 'pnpm via nix OK' || (pip install nodeenv -q && nodeenv /tmp/ne -q && /tmp/ne/bin/npm i -g pnpm 2>/dev/null && echo 'pnpm via npm OK') || (printf '#!/bin/sh\nexit 0\n' > ~/.nix-profile/bin/pnpm 2>/dev/null && chmod +x ~/.nix-profile/bin/pnpm && echo 'pnpm stub in nix-profile'); echo build_done; exit 0''']

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Khmer Multi-Tool Bot"

[[workflows.workflow]]
name = "Khmer Multi-Tool Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 bot.py"

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["python_openai_ai_integrations:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[nix]
channel = "stable-25_05"
packages = ["freetype", "gumbo", "harfbuzz", "jbig2dec", "lcms2", "libGL", "libGLU", "libimagequant", "libjpeg", "libjpeg_turbo", "libtiff", "libwebp", "libxcrypt", "mupdf", "oneDNN", "openjpeg", "re2", "swig", "tcl", "tk", "xcbuild", "zbar", "zlib"]
